####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/diskFront/bin || mkdir -p $(INSTALL_ROOT)/opt/diskFront/bin
	$(DEL_FILE) -r $(INSTALL_ROOT)/opt/diskFront/bin/diskFront.app
	
	$(QINSTALL) diskFront.app $(INSTALL_ROOT)/opt/diskFront/bin/diskFront.app

uninstall_target: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/opt/diskFront/bin/diskFront.app
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/diskFront/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

